# Like2D Framework .gitignore
# Professional Git ignore file for Like2D project

# =============================================================================
# BUILD ARTIFACTS
# =============================================================================

# Build directory
build/
Build/

# Object files
*.o
*.obj
*.o.d

# Executables
*.exe
*.com
*.bat

# Dynamic libraries
*.dll
*.so
*.dylib

# Static libraries
*.a
*.lib

# Distribution folders
dist/
Like2D-Dist/
*-Dist/

# CMake build files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake

# =============================================================================
# EXTERNAL LIBRARIES
# =============================================================================

# External dependencies (heavy libraries)
external/SDL3/
external/Luau/
external/stb/

# Keep only empty structure or config files
!external/.gitkeep
!external/README.md

# =============================================================================
# IDE & EDITOR FILES
# =============================================================================

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains IDEs
.idea/
*.iml
*.ipr
*.iws

# Visual Studio
*.vcxproj*
*.sln
*.user
*.suo
*.ncb
*.opt
*.plg
*.aps

# Code::Blocks
*.cbp
*.layout

# Dev-C++
*.dev

# =============================================================================
# OPERATING SYSTEM FILES
# =============================================================================

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# =============================================================================
# LOGS & TEMPORARY FILES
# =============================================================================

# Log files
*.log
*.logs
logs/

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~
.cache/

# =============================================================================
# DEVELOPMENT & DEBUG FILES
# =============================================================================

# Debug files
*.pdb
*.ilk
*.exp
*.map

# Profiling
*.prof
*.profile

# Coverage reports
*.gcov
*.gcda
*.gcno
coverage/

# =============================================================================
# CONFIGURATION & BACKUP FILES
# =============================================================================

# Backup files
*.bak
*.backup
*.old
*.orig
*.rej

# Configuration overrides
config.local.*
settings.local.*

# =============================================================================
# ASSET & RESOURCE FILES (USER-GENERATED)
# =============================================================================

# User assets (keep examples)
assets/user/
!/assets/examples/

# User scripts
scripts/user/
!/scripts/examples/

# User builds
user_build/
user_dist/

# =============================================================================
# DEPENDENCY LOCK FILES
# =============================================================================

# Package manager lock files
package-lock.json
yarn.lock
composer.lock

# =============================================================================
# PERFORMANCE & ANALYSIS
# =============================================================================

# Benchmark results
benchmark/
benchmarks/
*.benchmark

# Memory dumps
*.dmp
*.hdmp
*.mdmp

# =============================================================================
# SECURITY & KEYS
# =============================================================================

# Private keys and certificates
*.pem
*.key
*.crt
*.p12
*.pfx

# Environment files
.env
.env.local
.env.*.local

# =============================================================================
# PROJECT SPECIFIC
# =============================================================================

# Like2D specific ignores
updates.txt.tmp
*.luau.tmp

# Test outputs
test_output/
test_results/

# Documentation build artifacts
docs/_build/
docs/site/

# =============================================================================
# ALLOWED EXCEPTIONS (IMPORTANT FILES TO KEEP)
# =============================================================================

# Keep these files even if they match patterns above
!.gitignore
!README.md
!LICENSE
!CHANGELOG.md
!CONTRIBUTING.md

# Keep essential configuration files
!CMakeLists.txt
!build.bat
!build-full.bat
!resource.rc

# Keep documentation source files
!docs/*.md
!docs/*.txt

# Keep essential source files
!src/**/*.cpp
!src/**/*.h
!include/**/*.h

# Keep example scripts and assets
!scripts/main.luau
!scripts/examples/
!assets/examples/

# Keep empty directory markers
!.gitkeep
